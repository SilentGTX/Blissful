{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Blissful",
  "version": "0.1.0",
  "identifier": "com.blissful.tv",
  "build": {
    "frontendDist": "../../blissful-mvs/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../blissful-mvs run dev",
    "beforeBuildCommand": "npm --prefix ../blissful-mvs run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Blissful",
        "fullscreen": true,
        "resizable": false,
        "width": 1920,
        "height": 1080
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 26
    }
  }
}
