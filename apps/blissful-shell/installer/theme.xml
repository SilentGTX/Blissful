<?xml version="1.0" encoding="utf-8"?>
<!--
  Blissful Setup theme. Adapted from WiX 3.x's stock HyperlinkTheme.xml
  (https://github.com/wixtoolset/wix3 — src/ext/BalExtension/wixstdba/
  Resources/HyperlinkTheme.xml).

  Key differences from a brand-new theme:
    - Uses the canonical namespace `http://wixtoolset.org/schemas/thmutil/2010`
      (WiX 3.x). The `v4/thmutil` namespace ignores Page-membership
      semantics, which caused our earlier text-overlap bug.
    - Success/Failure pages use NAMED controls (SuccessInstallHeader,
      SuccessUninstallHeader, etc.) — WixStdBA automatically toggles
      them based on the action. No VisibleCondition needed.
    - Big Blissful wordmark logo replaces the stock 64x64 logo+title combo
      (Window grown to 485x380, logo 350x200 at top, content shifted down).

  ASCII-only strings in theme.wxl — build.ps1's PowerShell text patching
  round-trip used to mojibake non-ASCII (UTF-8 ellipsis bytes).
-->
<Theme xmlns="http://wixtoolset.org/schemas/thmutil/2010">
  <Window Width="485" Height="380" HexStyle="100a0000" FontId="0">#(loc.Caption)</Window>
  <Font Id="0" Height="-12" Weight="500" Foreground="000000" Background="FFFFFF">Segoe UI</Font>
  <Font Id="1" Height="-24" Weight="500" Foreground="000000">Segoe UI</Font>
  <Font Id="2" Height="-22" Weight="500" Foreground="666666">Segoe UI</Font>
  <Font Id="3" Height="-12" Weight="500" Foreground="000000" Background="FFFFFF">Segoe UI</Font>
  <Font Id="4" Height="-12" Weight="500" Foreground="ff0000" Background="FFFFFF" Underline="yes">Segoe UI</Font>

  <Image X="67" Y="15" Width="350" Height="200" ImageFile="bundle-logo.png" Visible="yes"/>

  <Page Name="Help">
    <Text X="11" Y="230" Width="-11" Height="30" FontId="2" DisablePrefix="yes">#(loc.HelpHeader)</Text>
    <Text X="11" Y="262" Width="-11" Height="-50" FontId="3" DisablePrefix="yes">#(loc.HelpText)</Text>
    <Button Name="HelpCancelButton" X="-11" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0">#(loc.HelpCloseButton)</Button>
  </Page>

  <Page Name="Install">
    <Text X="11" Y="230" Width="-11" Height="30" FontId="2" DisablePrefix="yes">#(loc.InstallHeader)</Text>
    <Button Name="InstallButton" X="-91" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0">#(loc.InstallButton)</Button>
    <Button Name="WelcomeCancelButton" X="-11" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0">#(loc.WelcomeCancelButton)</Button>
  </Page>

  <Page Name="Options">
    <Text X="11" Y="230" Width="-11" Height="30" FontId="2" DisablePrefix="yes">#(loc.OptionsHeader)</Text>
    <Button Name="OptionsOkButton" X="-91" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0">#(loc.OptionsOkButton)</Button>
    <Button Name="OptionsCancelButton" X="-11" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0">#(loc.OptionsCancelButton)</Button>
  </Page>

  <!--
    Progress page. Header in FontId=2 (22pt grey, matches stock).
    "Status:" label + OverallProgressPackageText on one row, then the
    progress bar below. WixStdBA auto-updates the package text.
  -->
  <Page Name="Progress">
    <Text X="11" Y="230" Width="-11" Height="30" FontId="2" DisablePrefix="yes">#(loc.ProgressHeader)</Text>
    <Text X="11" Y="270" Width="70" Height="17" FontId="3" DisablePrefix="yes">#(loc.ProgressLabel)</Text>
    <Text Name="OverallProgressPackageText" X="85" Y="270" Width="-11" Height="17" FontId="3" DisablePrefix="yes">#(loc.OverallProgressPackageText)</Text>
    <Progressbar Name="OverallCalculatedProgressbar" X="11" Y="292" Width="-11" Height="15" />
    <Button Name="ProgressCancelButton" X="-11" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0">#(loc.ProgressCancelButton)</Button>
  </Page>

  <Page Name="Modify">
    <Text X="11" Y="230" Width="-11" Height="30" FontId="2" DisablePrefix="yes">#(loc.ModifyHeader)</Text>
    <Button Name="RepairButton" X="-171" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0" HideWhenDisabled="yes">#(loc.ModifyRepairButton)</Button>
    <Button Name="UninstallButton" X="-91" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0">#(loc.ModifyUninstallButton)</Button>
    <Button Name="ModifyCancelButton" X="-11" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0">#(loc.ModifyCloseButton)</Button>
  </Page>

  <!--
    Success / Failure pages use NAMED Text controls that WixStdBA picks
    by name based on the bundle action. We supply all variants; WixStdBA
    shows the right one (HideWhenDisabled hides the rest). This is the
    canonical WiX 3.x pattern.
  -->
  <Page Name="Success">
    <Text Name="SuccessHeader" X="11" Y="230" Width="-11" Height="30" FontId="2" HideWhenDisabled="yes" DisablePrefix="yes">#(loc.SuccessHeader)</Text>
    <Text Name="SuccessInstallHeader" X="11" Y="230" Width="-11" Height="30" FontId="2" HideWhenDisabled="yes" DisablePrefix="yes">#(loc.SuccessInstallHeader)</Text>
    <Text Name="SuccessRepairHeader" X="11" Y="230" Width="-11" Height="30" FontId="2" HideWhenDisabled="yes" DisablePrefix="yes">#(loc.SuccessRepairHeader)</Text>
    <Text Name="SuccessUninstallHeader" X="11" Y="230" Width="-11" Height="30" FontId="2" HideWhenDisabled="yes" DisablePrefix="yes">#(loc.SuccessUninstallHeader)</Text>
    <Button Name="LaunchButton" X="-91" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0" HideWhenDisabled="yes">#(loc.SuccessLaunchButton)</Button>
    <Button Name="SuccessCancelButton" X="-11" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0">#(loc.SuccessCloseButton)</Button>
  </Page>

  <Page Name="Failure">
    <Text Name="FailureHeader" X="11" Y="230" Width="-11" Height="30" FontId="2" HideWhenDisabled="yes" DisablePrefix="yes">#(loc.FailureHeader)</Text>
    <Text Name="FailureInstallHeader" X="11" Y="230" Width="-11" Height="30" FontId="2" HideWhenDisabled="yes" DisablePrefix="yes">#(loc.FailureInstallHeader)</Text>
    <Text Name="FailureUninstallHeader" X="11" Y="230" Width="-11" Height="30" FontId="2" HideWhenDisabled="yes" DisablePrefix="yes">#(loc.FailureUninstallHeader)</Text>
    <Text Name="FailureRepairHeader" X="11" Y="230" Width="-11" Height="30" FontId="2" HideWhenDisabled="yes" DisablePrefix="yes">#(loc.FailureRepairHeader)</Text>
    <Hypertext Name="FailureLogFileLink" X="11" Y="270" Width="-11" Height="42" FontId="3" TabStop="yes" HideWhenDisabled="yes">#(loc.FailureHyperlinkLogText)</Hypertext>
    <Button Name="FailureCloseButton" X="-11" Y="-11" Width="75" Height="23" TabStop="yes" FontId="0">#(loc.FailureCloseButton)</Button>
  </Page>
</Theme>
