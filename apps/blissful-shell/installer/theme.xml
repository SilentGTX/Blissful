<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom WiX Burn theme for Blissful Setup.

  Layout (485w x 340h):
    Y=0..15      top margin
    Y=15..215    Blissful wordmark logo (350x200 PNG, centered X=67)
    Y=215..235   gap
    Y=235..275   page-specific text area (header + optional sub-text)
    Y=-11..-38   bottom-right button row (X=-11 / X=-100 / X=-185)

  Notes:
    - WiX 3.x thmutil only honors VisibleCondition (NOT EnableCondition);
      avoid trying to differentiate WixBundleAction across page-internal
      controls — it leaks across pages. Use ONE neutral text per page
      and only differentiate via WixStdBA's exposed flags
      (WixStdBALaunchTargetExists in particular).
    - ASCII-only strings in theme.wxl: build.ps1's text patching round-
      trip mojibakes non-ASCII through PowerShell 5.1's codepage
      defaults.
-->
<Theme xmlns="http://wixtoolset.org/schemas/v4/thmutil">
  <Window Width="485" Height="340" HexStyle="100a0000" FontId="0">#(loc.Caption)</Window>
  <Font Id="0" Height="-12" Weight="500" Foreground="000000" Background="ffffff">Segoe UI</Font>
  <Font Id="1" Height="-18" Weight="500" Foreground="000000">Segoe UI</Font>

  <Image X="67" Y="15" Width="350" Height="200" ImageFile="bundle-logo.png" Visible="yes" />

  <Page Name="Help">
    <Text X="20" Y="235" Width="445" Height="40" FontId="0" DisablePrefix="yes">#(loc.HelpText)</Text>
    <Button Name="HelpCloseButton" X="-11" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0">#(loc.HelpCloseButton)</Button>
  </Page>

  <Page Name="Install">
    <Text X="20" Y="240" Width="445" Height="28" FontId="1" DisablePrefix="yes">#(loc.InstallHeader)</Text>
    <Button Name="InstallButton" X="-100" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0">#(loc.InstallButton)</Button>
    <Button Name="WelcomeCancelButton" X="-11" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0">#(loc.WelcomeCancelButton)</Button>
  </Page>

  <Page Name="Options">
    <Text X="20" Y="240" Width="445" Height="28" FontId="1" DisablePrefix="yes">#(loc.OptionsHeader)</Text>
    <Button Name="OptionsOkButton" X="-100" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0">#(loc.OptionsOkButton)</Button>
    <Button Name="OptionsCancelButton" X="-11" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0">#(loc.OptionsCancelButton)</Button>
  </Page>

  <!--
    Progress page. Use FontId=0 (small/regular) for BOTH the header and
    the package-name text so they don't visually run into each other.
    WixStdBA auto-updates `OverallProgressPackageText` to the current
    package name ("Blissful") during install/uninstall.
  -->
  <Page Name="Progress">
    <Text X="20" Y="240" Width="445" Height="18" FontId="0" DisablePrefix="yes">#(loc.ProgressHeader)</Text>
    <Text Name="OverallProgressPackageText" X="20" Y="262" Width="445" Height="18" FontId="0" DisablePrefix="yes">#(loc.OverallProgressPackageText)</Text>
    <Progressbar Name="OverallCalculatedProgressbar" X="20" Y="288" Width="445" Height="15" />
    <Button Name="ProgressCancelButton" X="-11" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0">#(loc.ProgressCancelButton)</Button>
  </Page>

  <Page Name="Modify">
    <Text X="20" Y="240" Width="445" Height="28" FontId="1" DisablePrefix="yes">#(loc.ModifyHeader)</Text>
    <Button Name="RepairButton" X="-185" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0">#(loc.RepairButton)</Button>
    <Button Name="UninstallButton" X="-100" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0">#(loc.UninstallButton)</Button>
    <Button Name="ModifyCancelButton" X="-11" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0">#(loc.ModifyCancelButton)</Button>
  </Page>

  <Page Name="Success">
    <Text X="20" Y="240" Width="445" Height="28" FontId="1" DisablePrefix="yes">#(loc.SuccessHeader)</Text>
    <Button Name="LaunchButton" X="-100" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0"
            VisibleCondition="WixStdBALaunchTargetExists">#(loc.LaunchButton)</Button>
    <Button Name="SuccessCancelButton" X="-11" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0">#(loc.SuccessCloseButton)</Button>
  </Page>

  <Page Name="Failure">
    <Text X="20" Y="240" Width="445" Height="60" FontId="0" DisablePrefix="yes">#(loc.FailureHeader)</Text>
    <Hypertext Name="FailureLogFileLink" X="20" Y="295" Width="445" Height="17" FontId="0" TabStop="yes" HideWhenDisabled="yes">#(loc.FailureHyperlinkLogText)</Hypertext>
    <Button Name="FailureCloseButton" X="-11" Y="-11" Width="85" Height="27" TabStop="yes" FontId="0">#(loc.FailureCloseButton)</Button>
  </Page>
</Theme>
