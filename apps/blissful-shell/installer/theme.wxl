<?xml version="1.0" encoding="utf-8"?>
<!--
  Localization strings for the Blissful Setup bundle theme. Strings
  referenced as #(loc.Name) inside theme.xml. Keep short â€” the dialog
  is intentionally minimal. SuccessInstallHeader / SuccessRepairHeader /
  SuccessUninstallHeader are picked at runtime via EnableCondition.
-->
<WixLocalization xmlns="http://wixtoolset.org/schemas/v4/wxl" Culture="en-us">
  <!-- Title bar text. Format copied from Stremio's installer:
       "Setup - Blissful version X.Y.Z". The version is patched in at
       build time by build.ps1 (replaces @VERSION@ with $rawVersion
       from Cargo.toml). DON'T hand-edit the version part â€” it's
       auto-substituted. -->
  <String Id="Caption">Setup - Blissful version @VERSION@</String>

  <String Id="HelpText">Pass /install, /modify, /repair, /uninstall on the command line.</String>
  <String Id="HelpCloseButton">&amp;Close</String>

  <!-- Message shown when the user closes/cancels mid-install. WixStdBA
       looks up this exact key by name â€” it wasn't in our wxl before, so
       Burn rendered the literal "#(loc.ConfirmCancelMessage)" placeholder. -->
  <String Id="ConfirmCancelMessage">Are you sure you want to cancel?</String>

  <String Id="InstallHeader">Click Install to install Blissful.</String>
  <String Id="InstallButton">&amp;Install</String>
  <String Id="WelcomeCancelButton">&amp;Close</String>

  <String Id="OptionsHeader">Options</String>
  <String Id="OptionsOkButton">&amp;OK</String>
  <String Id="OptionsCancelButton">&amp;Cancel</String>

  <String Id="ProgressHeader">Installing Blissfulâ€¦</String>
  <String Id="ProgressCancelButton">&amp;Cancel</String>
  <String Id="OverallProgressPackageText">Initializingâ€¦</String>

  <String Id="ModifyHeader">Modify, repair, or uninstall Blissful.</String>
  <String Id="RepairButton">&amp;Repair</String>
  <String Id="UninstallButton">&amp;Uninstall</String>
  <String Id="ModifyCancelButton">&amp;Cancel</String>

  <String Id="SuccessInstallHeader">Blissful installed.</String>
  <String Id="SuccessRepairHeader">Blissful repaired.</String>
  <String Id="SuccessUninstallHeader">Blissful uninstalled.</String>
  <String Id="LaunchButton">&amp;Launch</String>
  <String Id="SuccessCloseButton">&amp;Close</String>

  <String Id="FailureHeader">Setup failed. The log has details on what went wrong.</String>
  <String Id="FailureHyperlinkLogText">View &lt;a href="#"&gt;log&lt;/a&gt;</String>
  <String Id="FailureCloseButton">&amp;Close</String>
</WixLocalization>

