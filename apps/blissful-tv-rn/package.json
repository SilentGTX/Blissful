{
  "name": "blissful-tv-rn",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "prebuild:tv": "cross-env EXPO_TV=1 expo prebuild --platform android --clean",
    "web": "expo start --web",
    "link:core": "node scripts/link-core.js",
    "build:release": "npm run link:core && cd android && gradlew assembleRelease",
    "postinstall": "node scripts/link-core.js"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/ibm-plex-sans": "^0.4.1",
    "@expo-google-fonts/spectral": "^0.4.1",
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/stack": "^7.9.3",
    "expo": "~56.0.9",
    "expo-font": "~56.0.5",
    "expo-image": "~56.0.10",
    "expo-linear-gradient": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-video": "~56.1.2",
    "react": "19.2.3",
    "react-native": "npm:react-native-tvos@0.85.3-0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@react-native-tvos/config-tv": "^0.1.6",
    "@types/react": "~19.2.2",
    "cross-env": "^7.0.3",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "react-native": "npm:react-native-tvos@0.85.3-0"
  },
  "private": true
}
