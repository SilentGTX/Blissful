# Node
node_modules/
npm-debug.log*
.npm/

# Build outputs
apps/blissful-mvs/dist/
apps/blissful-mvs/dev-dist/
apps/blissful-shell/target/

# Bundled runtime binaries (downloaded by setup script, not committed)
apps/blissful-shell/resources/mpv-x64/
apps/blissful-shell/resources/ffmpeg-dlls/
apps/blissful-shell/resources/test-media/
apps/blissful-shell/resources/stremio-service.zip
apps/blissful-shell/resources/stremio-service/
# vcruntime DLLs are MSVC redistributables — staged per-dev / fetched by
# the CI workflow at build time, never tracked in git.
apps/blissful-shell/resources/vcruntime/*.dll

# Installer output + WiX intermediates left behind by local builds
apps/blissful-shell/installer/build/
apps/blissful-shell/installer/dist/
apps/blissful-shell/installer/obj/
apps/blissful-shell/installer/staging/
apps/blissful-shell/installer/staging-files.wxs
apps/blissful-shell/installer/*.msi
apps/blissful-shell/installer/*.exe

# Local-only zips packaged for vendor-binaries-* GitHub release uploads
vendor-binaries/

# Editor / OS
.DS_Store
.idea/
.vscode/
.claude/
*.swp
*.swo
Thumbs.db
desktop.ini

# Local env
.env
.env.local
*.local
