# Node
node_modules/
npm-debug.log*
.npm/

# Build outputs
apps/web-blissful/dist/
apps/web-blissful/dev-dist/
apps/desktop-blissful/target/

# Bundled runtime binaries (downloaded by setup script, not committed)
apps/desktop-blissful/resources/mpv-x64/
apps/desktop-blissful/resources/ffmpeg-dlls/
apps/desktop-blissful/resources/test-media/
apps/desktop-blissful/resources/stremio-service.zip
apps/desktop-blissful/resources/stremio-service/
# vcruntime DLLs are MSVC redistributables — staged per-dev / fetched by
# the CI workflow at build time, never tracked in git.
apps/desktop-blissful/resources/vcruntime/*.dll

# Installer output + WiX intermediates left behind by local builds
apps/desktop-blissful/installer/build/
apps/desktop-blissful/installer/dist/
apps/desktop-blissful/installer/obj/
apps/desktop-blissful/installer/staging/
apps/desktop-blissful/installer/staging-files.wxs
apps/desktop-blissful/installer/*.msi
apps/desktop-blissful/installer/*.exe

# Local-only zips packaged for vendor-binaries-* GitHub release uploads
vendor-binaries/

# Editor / OS
.DS_Store
.idea/
.vscode/
.claude/
*.swp
*.swo
Thumbs.db
desktop.ini

